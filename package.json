{
  "name": "datapitfalls",
  "version": "0.2.0",
  "description": "Helping you steer clear of common blunders when working with data. Based on Avoiding Data Pitfalls by Ben Jones.",
  "author": "Ben Jones <bjones@dataliteracy.com> (https://dataliteracy.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjonesdataliteracy/datapitfalls.git"
  },
  "homepage": "https://www.avoidingdatapitfalls.com",
  "bugs": {
    "url": "https://github.com/bjonesdataliteracy/datapitfalls/issues"
  },
  "keywords": [
    "data-quality",
    "data-literacy",
    "data-visualization",
    "pitfall-detector",
    "data-pitfalls",
    "avoiding-data-pitfalls",
    "ai",
    "linting",
    "data-analysis"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "workspaces": [
    "web"
  ],
  "bin": {
    "datapitfalls": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:taxonomy && tsc",
    "build:taxonomy": "node scripts/build-taxonomy.mjs",
    "prepack": "npm run build",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs",
    "validate": "node scripts/validate-taxonomy.mjs",
    "eval": "node evals/run.mjs",
    "preverify": "npm run build",
    "verify": "node verify/run.mjs",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "mammoth": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "ajv": "^8.20.0",
    "eslint": "^8.57.1",
    "js-yaml": "^4.1.1",
    "prettier": "^3.5.0",
    "typescript": "^5.7.3"
  }
}
